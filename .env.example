# RoboVision Agent — Environment Configuration
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.

# ── LLM API (OpenAI-compatible) ──────────────────────────────
# Required. Get your key from your LLM provider.
LLM_API_KEY=your_api_key_here
# Base URL for OpenAI-compatible API.
# For local Ollama: http://localhost:11434/v1
# For DeepSeek API: https://api.deepseek.com/v1
LLM_BASE_URL=http://localhost:11434/v1
# Model name to use for chat completion.
LLM_MODEL=gemma4:31b
# Disabled by default so the application remains usable without an LLM service.
LLM_ENABLED=false
# Fail fast when an optional LLM service is unavailable.
LLM_TIMEOUT_SECONDS=30

# Optional local SentenceTransformer directory. Leave empty to use the model name.
EMBEDDING_MODEL_PATH=

# Experimental colour heuristic. Keep disabled for normal fire alarms.
ENABLE_HSV_FIRE_FALLBACK=false

# Optional override for the fire/smoke model path. The default is
# weights/fire_smoke_yolov8n.pt; see weights/README.md for provenance.
FIRE_SMOKE_MODEL=weights/fire_smoke_yolov8n.pt

# ── WeChat Work bot (Optional) ───────────────────────────────
# Webhook key from Enterprise WeChat bot. Leave empty to skip notifications.
WECHAT_ENABLED=false
WECHAT_WEBHOOK_KEY=
